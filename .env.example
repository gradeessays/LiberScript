# ──────────────────────────────────────────────────────────────────────────
# Liberscript environment — copy to .env and fill in.
# Values here are safe local defaults that match docker-compose.yml.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (Postgres)
# Local: docker-compose, OR a Postgres on any reachable host (no Docker needed).
DATABASE_URL=postgresql://liberscript:liberscript@localhost:5432/liberscript?schema=public
# Prod (DO Managed Postgres): append ?sslmode=require to the connection string, e.g.
#   postgresql://USER:PASS@db-host.db.ondigitalocean.com:25060/liberscript?sslmode=require

# Redis (BullMQ queue)
# Local: redis://localhost:6379
# Prod (DO Managed Redis/Valkey): use the TLS scheme rediss:// to enable TLS, e.g.
#   rediss://default:PASS@redis-host.db.ondigitalocean.com:25061
REDIS_URL=redis://localhost:6379

# Auth (better-auth) — generate with: openssl rand -base64 32
AUTH_SECRET=dev-only-change-me-please-32-bytes-min
# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption for user-supplied AI API keys (AES-256-GCM).
# Must be 32 bytes, base64-encoded. Generate: openssl rand -base64 32
ENCRYPTION_KEY=dev-only-base64-32byte-key-replace-me========

# Object storage
# STORAGE_DRIVER=local  → files are written to disk (.data/uploads). No service
#   needed for local dev. The web app serves signed upload/download URLs.
# STORAGE_DRIVER=s3     → DO Spaces / S3 / MinIO (set the S3_* values below).
STORAGE_DRIVER=local
# Optional absolute dir for the local driver (default: <repo>/.data/uploads)
# STORAGE_LOCAL_DIR=

# S3-compatible storage (only required when STORAGE_DRIVER=s3).
# Prod (DO Spaces): S3_ENDPOINT=https://<region>.digitaloceanspaces.com,
#   S3_REGION=<region>, S3_FORCE_PATH_STYLE=false, plus a Spaces key/secret.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Email
# MAIL_DRIVER=log  → verification/reset/invite links print to the console (dev).
# MAIL_DRIVER=smtp → send via the SMTP server below (MailHog locally, or a
#   transactional provider like Postmark/SES in prod).
MAIL_DRIVER=log
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Liberscript <no-reply@liberscript.local>"

# Billing (Stripe) — leave blank until Phase 8
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=debug
