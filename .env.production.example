# ─────────────────────────────────────────────────────────────────────────────
# Liberscript — production environment (copy to .env.production and fill in).
# Used by docker-compose.prod.yml for the web + worker + caddy containers.
# Keep the real .env.production OUT of git (already gitignored).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Public URL of the site (used for auth callbacks, emails, OAuth). Must match the
# domain Caddy serves below.
APP_URL=https://your-domain.com

# ── Reverse proxy / TLS (Caddy) ──────────────────────────────────────────────
APP_DOMAIN=your-domain.com
ACME_EMAIL=you@example.com

# ── Database: Neon (free tier) ───────────────────────────────────────────────
# Use the POOLED connection string (host contains "-pooler"); connect/pool
# timeouts are appended automatically for cold-start resilience.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# ── Redis: Upstash (free tier) ───────────────────────────────────────────────
# Use the rediss:// (TLS) URL from the Upstash console.
REDIS_URL=rediss://default:PASSWORD@your-db.upstash.io:6379

# ── Secrets (generate with: openssl rand -base64 32) ─────────────────────────
AUTH_SECRET=replace-with-32+char-random-string
ENCRYPTION_KEY=replace-with-base64-32-byte-key

# ── Object storage: Cloudflare R2 (free 10GB, zero egress) ───────────────────
# Create a bucket + an R2 API token (Object Read & Write). Set a CORS rule on the
# bucket allowing PUT/GET from APP_URL so browser uploads work.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=liberscript
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=false

# ── Email (transactional SMTP) ───────────────────────────────────────────────
MAIL_DRIVER=smtp
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Liberscript <no-reply@your-domain.com>

# ── Print-PDF export: Chromium is baked into the worker image; no config needed.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium  # (already set in the image)

# ── Optional integrations ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# SENTRY_DSN=
LOG_LEVEL=info
