# Normalize line endings to LF in the repo across platforms.
* text=auto eol=lf

# Binary/asset types — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.epub binary
*.docx binary

# Lockfiles: keep LF, mark as generated for diffs.
pnpm-lock.yaml linguist-generated=true
