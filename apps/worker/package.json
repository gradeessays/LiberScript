    "@liberscript/storage": "workspace:*",
    "bullmq": "^5.21.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@liberscript/config": "workspace:*",
    "@types/node": "^20.16.11",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
