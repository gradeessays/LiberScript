{
  "name": "liberscript",
  "version": "0.0.0",
  "private": true,
  "description": "Liberscript — a unified publishing workspace: write, analyze, format, and export your book under one roof.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @liberscript/db generate",
    "db:migrate": "pnpm --filter @liberscript/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @liberscript/db migrate:deploy",
    "db:migrate:prod": "pnpm --filter @liberscript/db migrate:prod",
    "db:seed": "pnpm --filter @liberscript/db seed",
    "db:studio": "pnpm --filter @liberscript/db studio",
    "clean": "turbo run clean && rimraf node_modules",
    "ensure-keys": "node scripts/ensure-keys.js"
  },
  "devDependencies": {
    "@liberscript/config": "workspace:*",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
